{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "markdown-crawler",
  "main": "worker.ts",
  "compatibility_date": "2025-12-14",
  "observability": { "logs": { "enabled": true } },
  "assets": { "directory": "./public" },
  "durable_objects": {
    "bindings": [{ "name": "DomainDO", "class_name": "DomainDO" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["DomainDO"] }],
  "routes": [{ "custom_domain": true, "pattern": "crawl.llmtext.com" }]
}
